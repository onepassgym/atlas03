{
  "name": "atlas06-scraper",
  "version": "1.0.0",
  "description": "Atlas06 - Google Maps Fitness Venue Scraper (Node 20, no API key)",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "worker": "node src/queue/worker.js",
    "dev:worker": "nodemon src/queue/worker.js",
    "worker:chain": "node src/queue/chainWorker.js",
    "dev:worker:chain": "nodemon src/queue/chainWorker.js",
    "worker:enrich": "node src/queue/enrichmentWorker.js",
    "dev:worker:enrich": "nodemon src/queue/enrichmentWorker.js",
    "queue:cities": "node scripts/queueCities.js",
    "retry:failed": "node scripts/retryFailed.js",
    "retry:incomplete": "node scripts/retryFailed.js --incomplete",
    "db:stats": "node scripts/dbStats.js",
    "db:export": "node scripts/dbStats.js --export",
    "setup": "npx playwright install chromium --with-deps",
    "docs:snapshot": "node scripts/genArchSnapshot.js",
    "dashboard:dev": "cd dashboard && npm run dev",
    "dashboard:build": "cd dashboard && npm run build",
    "dashboard:install": "cd dashboard && npm install",
    "dev:all": "concurrently -c \"cyan,magenta,yellow,green,blue\" \"npm run dev\" \"npm run dev:worker\" \"npm run dev:worker:enrich\" \"npm run dev:worker:chain\" \"npm run dashboard:dev\""
  },
  "dependencies": {
    "axios": "1.7.2",
    "bullmq": "^5.71.0",
    "compression": "1.7.4",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "express-rate-limit": "7.3.1",
    "express-validator": "7.1.0",
    "generic-pool": "^3.9.0",
    "geolib": "3.3.4",
    "helmet": "7.1.0",
    "ioredis": "5.4.1",
    "mongoose": "8.4.1",
    "morgan": "1.10.0",
    "node-cron": "3.0.3",
    "p-limit": "^5.0.0",
    "p-retry": "6.2.0",
    "playwright": "1.44.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sharp": "0.33.4",
    "slugify": "1.6.6",
    "uuid": "10.0.0",
    "winston": "3.13.0",
    "winston-daily-rotate-file": "5.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "3.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
