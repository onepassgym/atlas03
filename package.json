{
  "name": "atlas05-scraper",
  "version": "1.0.0",
  "description": "Atlas05 - Google Maps Fitness Venue Scraper (Node 20, no API key)",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "worker": "node src/queue/worker.js",
    "dev:worker": "nodemon src/queue/worker.js",
    "queue:cities": "node scripts/queueCities.js",
    "retry:failed": "node scripts/retryFailed.js",
    "retry:incomplete": "node scripts/retryFailed.js --incomplete",
    "db:stats": "node scripts/dbStats.js",
    "db:export": "node scripts/dbStats.js --export",
    "setup": "npx playwright install chromium --with-deps"
  },
  "dependencies": {
    "express": "4.19.2",
    "mongoose": "8.4.1",
    "playwright": "1.44.1",
    "bull": "4.12.9",
    "ioredis": "5.4.1",
    "axios": "1.7.2",
    "sharp": "0.33.4",
    "slugify": "1.6.6",
    "winston": "3.13.0",
    "winston-daily-rotate-file": "5.0.0",
    "dotenv": "16.4.5",
    "express-rate-limit": "7.3.1",
    "express-validator": "7.1.0",
    "helmet": "7.1.0",
    "morgan": "1.10.0",
    "compression": "1.7.4",
    "cors": "2.8.5",
    "geolib": "3.3.4",
    "uuid": "10.0.0",
    "p-limit": "5.0.0",
    "p-retry": "6.2.0",
    "node-cron": "3.0.3"
  },
  "devDependencies": {
    "nodemon": "3.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
