# ============================================================
#  Atlas05 Scraper — Environment Config
#  Ports chosen to avoid conflicts with common dev tools:
#    API   → 8747  (not 3000/8000/8080)
#    Mongo → 27328 (not 27017)
#    Redis → 6847  (not 6379)
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=8747
NODE_ENV=development

# ── MongoDB ──────────────────────────────────────────────────
# Local (non-default port)
MONGODB_URI=mongodb://127.0.0.1:27328/atlas05
MONGODB_DB_NAME=atlas05

# Atlas (uncomment + fill to use cloud):
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/atlas05

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6847
REDIS_PASSWORD=

# ── Media Storage ────────────────────────────────────────────
MEDIA_BASE_PATH=./media
MEDIA_BASE_URL=http://localhost:8747/media

# Production (update on VPS):
# MEDIA_BASE_URL=https://atlas.onepassgym.cloud/media

# ── Scraper Behaviour ────────────────────────────────────────
SCRAPER_CONCURRENCY=2
SCRAPER_DELAY_MIN=1500
SCRAPER_DELAY_MAX=4000
SCRAPER_TIMEOUT=30000
SCRAPER_MAX_RETRIES=3
SCRAPER_HEADLESS=true

# ── Deduplication ────────────────────────────────────────────
DEDUP_RADIUS_METERS=50

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs
