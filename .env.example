# ============================================================
#  Atlas05 Scraper — Environment Config
# ============================================================

# ── General ──────────────────────────────────────────────────
# Switch between 'development' and 'production' (or 'prod')
NODE_ENV=development
PORT=8747

# ── Development Specific (Auto-selected if NODE_ENV=development) ─────────────
DEV_MONGODB_URI=mongodb://127.0.0.1:27328/atlas05
DEV_REDIS_HOST=127.0.0.1
DEV_REDIS_PORT=6847
DEV_MEDIA_BASE_URL=http://localhost:8747/media

# ── Production Specific (Auto-selected if NODE_ENV=production) ───────────────
# When running with Docker Compose, use 'mongo' and 'redis' container names
PROD_MONGODB_URI=mongodb://mongo:27017/atlas05
PROD_REDIS_HOST=redis
PROD_REDIS_PORT=6379
PROD_MEDIA_BASE_URL=https://atlas.onepassgym.com/media

# ── MongoDB Common ───────────────────────────────────────────
MONGODB_DB_NAME=atlas05

# ── Redis Common ─────────────────────────────────────────────
REDIS_PASSWORD=

# ── Media Storage ────────────────────────────────────────────
MEDIA_BASE_PATH=./media

# ── Scraper Behaviour ────────────────────────────────────────
# BullMQ concurrency per worker replica (batch jobs processed at once)
SCRAPER_CONCURRENCY=3
# Inter-URL delay (ms) — stealth plugin handles anti-detection
SCRAPER_DELAY_MIN=300
SCRAPER_DELAY_MAX=800
SCRAPER_TIMEOUT=30000
SCRAPER_MAX_RETRIES=3
SCRAPER_HEADLESS=true
# Parallel browser tabs per batch job (6 for 8GB VPS, 3 for 4GB)
SCRAPER_PAGE_POOL=6
# Parallel search pages for discovery phase
SCRAPER_SEARCH_POOL=3
# Skip gyms crawled within N days on re-crawl (0 = always re-scrape)
SCRAPER_SKIP_RECENT_DAYS=7
# Phase 9: URLs per batch job (smaller = more parallelism)
SCRAPER_BATCH_SIZE=15
# Depth caps: 'standard' uses these, 'deep' = 150/80, 'fast' = 0
SCRAPER_MAX_REVIEWS=30
SCRAPER_MAX_PHOTOS=20
# Media worker concurrency (pure I/O, no Chromium — 8-10 is fine)
MEDIA_WORKER_CONCURRENCY=8

# ── Deduplication ────────────────────────────────────────────
DEDUP_RADIUS_METERS=50

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs
