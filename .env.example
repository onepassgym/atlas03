# ============================================================
#  Atlas05 Scraper — Environment Config
# ============================================================

# ── General ──────────────────────────────────────────────────
# Switch between 'development' and 'production' (or 'prod')
NODE_ENV=development
PORT=8747

# ── Development Specific (Auto-selected if NODE_ENV=development) ─────────────
DEV_MONGODB_URI=mongodb://127.0.0.1:27328/atlas05
DEV_REDIS_HOST=127.0.0.1
DEV_REDIS_PORT=6847
DEV_MEDIA_BASE_URL=http://localhost:8747/media

# ── Production Specific (Auto-selected if NODE_ENV=production) ───────────────
# When running with Docker Compose, use 'mongo' and 'redis' container names
PROD_MONGODB_URI=mongodb://mongo:27017/atlas05
PROD_REDIS_HOST=redis
PROD_REDIS_PORT=6379
PROD_MEDIA_BASE_URL=https://atlas.onepassgym.cloud/media

# ── MongoDB Common ───────────────────────────────────────────
MONGODB_DB_NAME=atlas05

# ── Redis Common ─────────────────────────────────────────────
REDIS_PASSWORD=

# ── Media Storage ────────────────────────────────────────────
MEDIA_BASE_PATH=./media

# ── Scraper Behaviour ────────────────────────────────────────
SCRAPER_CONCURRENCY=2
SCRAPER_DELAY_MIN=1500
SCRAPER_DELAY_MAX=4000
SCRAPER_TIMEOUT=30000
SCRAPER_MAX_RETRIES=3
SCRAPER_HEADLESS=true

# ── Deduplication ────────────────────────────────────────────
DEDUP_RADIUS_METERS=50

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs
